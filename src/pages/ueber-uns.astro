---
import MainLayout from "../layouts/MainLayout.astro";
const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + "/";
---

<MainLayout title="Monika Stitch – Über uns">
  <!-- Hero -->
  <section class="py-16 sm:py-20 bg-transparent">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="font-body text-sm uppercase tracking-[0.3em] text-[#C9A96E] mb-3">Unsere Geschichte</p>
      <h1 class="font-heading text-4xl sm:text-5xl text-white font-bold mb-6">Über Monika Stitch</h1>
      <p class="font-body text-lg text-white/70 max-w-2xl mx-auto leading-relaxed">
        Moderne Maschinenstickerei trifft auf persönliche Beratung und kreatives Design – das ist Monika Stitch.
      </p>
    </div>
  </section>

  <!-- Story -->
  <section class="py-16 bg-white/[0.02] border-y border-white/5 backdrop-blur-sm">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="font-heading text-3xl text-white font-bold mb-6">Moderne Technik, persönliche Note</h2>
          <div class="space-y-4 font-body text-white/70 leading-relaxed">
            <p>
              Monika Stitch wurde aus der Begeisterung für Stickerei und dem Wunsch gegründet,
              hochwertige, individuelle Stickarbeiten anzubieten. Als Ein-Frau-Betrieb stehe ich
              persönlich hinter jedem Projekt – von der Beratung bis zum fertigen Ergebnis.
            </p>
            <p>
              Herzstück meiner Arbeit ist die Brother PR1060W – eine professionelle Mehrnadelmaschine,
              die präzise, detailreiche Stickereien ermöglicht. Damit lässt sich nahezu alles besticken:
              Caps, T-Shirts, Polos, Jacken, Hoodies, Handtücher, Taschen, Kissen und vieles mehr.
            </p>
            <p>
              Trotz modernster Technik ist jedes Stück ein Unikat. Ich berate Sie persönlich, gestalte
              Ihr Wunschmotiv und sorge dafür, dass das Ergebnis genau Ihren Vorstellungen entspricht –
              ob individuelles Geschenk, Firmenlogo oder kreatives Design.
            </p>
          </div>
        </div>

        <div class="relative">
          <div class="aspect-[4/3] rounded-2xl bg-gradient-to-br from-[#C9A96E]/20 to-[#0f172a]/80 border border-white/10 flex items-center justify-center overflow-hidden">
            <svg width="200" height="200" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg" class="opacity-60">
              <circle cx="100" cy="100" r="80" stroke="#C9A96E" stroke-width="3" fill="none"/>
              <circle cx="100" cy="100" r="70" stroke="#C9A96E" stroke-width="1.5" fill="none" opacity="0.5"/>
              <path d="M60 80 C70 60 90 70 100 90 S120 110 130 95" stroke="#D4A5A5" stroke-width="3" fill="none" stroke-linecap="round"/>
              <path d="M55 110 C65 90 85 100 95 120 S115 140 125 125" stroke="#9CAF88" stroke-width="3" fill="none" stroke-linecap="round"/>
              <path d="M70 130 C80 115 95 125 105 135 S120 125 130 130" stroke="#C9A96E" stroke-width="2" fill="none" stroke-linecap="round"/>
            </svg>
          </div>
          <div class="absolute -bottom-4 -right-4 w-24 h-24 bg-[#C9A96E]/10 border border-white/5 rounded-2xl -z-10"></div>
          <div class="absolute -top-4 -left-4 w-16 h-16 bg-[#D4A5A5]/10 border border-white/5 rounded-xl -z-10"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-16 bg-transparent">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-3xl text-white font-bold text-center mb-12">Unsere Werte</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { title: "Präzision", desc: "Die Brother PR1060W liefert gestochen scharfe Ergebnisse bei jedem Motiv.", color: "border-rose", icon: "M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5M9 11.25v1.5M12 9v3.75m3-6v6", stitch: "#D4A5A5" },
          { title: "Qualität", desc: "Hochwertige Garne und Materialien für langlebige, brillante Stickereien.", color: "border-sage", icon: "M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.745 3.745 0 011.043 3.296A3.745 3.745 0 0121 12z", stitch: "#9CAF88" },
          { title: "Individualität", desc: "Ihr Wunschmotiv, Ihre Farben, Ihr Unikat – persönlich beraten und umgesetzt.", color: "border-gold", icon: "M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42", stitch: "#C9A96E" },
          { title: "Vielseitigkeit", desc: "Von Caps über Jacken bis Heimtextilien – wir besticken nahezu alles.", color: "border-rose-dark", icon: "M6.429 9.75L2.25 12l4.179 2.25m0-4.5l5.571 3 5.571-3m-11.142 0L2.25 7.5 12 2.25l9.75 5.25-4.179 2.25m0 0L21.75 12l-4.179 2.25m0 0L21.75 16.5 12 21.75 2.25 16.5l4.179-2.25m11.142 0l-5.571 3-5.571-3", stitch: "#B88A8A" },
        ].map((value) => (
          <div class:list={["group relative overflow-hidden bg-white/[0.02] backdrop-blur-md rounded-2xl p-7 text-center shadow-sm hover:shadow-[0_8px_30px_rgba(0,0,0,0.3)] hover:border-white/10 hover:-translate-y-1.5 transition-all duration-300 border border-white/5 border-t-4", value.color]}>
            <div class="w-12 h-12 mx-auto mb-4 rounded-full bg-transparent flex items-center justify-center">
              <svg class="w-6 h-6 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={value.icon}/>
              </svg>
            </div>
            <h3 class="font-heading text-lg text-white font-semibold mb-2">{value.title}</h3>
            <p class="font-body text-sm text-white/70">{value.desc}</p>
            <svg class="absolute bottom-2 right-2 w-6 h-6 opacity-[0.07] group-hover:opacity-[0.15] transition-opacity duration-300" viewBox="0 0 16 12" fill="none" aria-hidden="true">
              <line x1="2" y1="2" x2="6" y2="6" stroke={value.stitch} stroke-width="1.3" stroke-linecap="round"/><line x1="6" y1="2" x2="2" y2="6" stroke={value.stitch} stroke-width="1.3" stroke-linecap="round"/>
              <line x1="8" y1="2" x2="12" y2="6" stroke={value.stitch} stroke-width="1.3" stroke-linecap="round"/><line x1="12" y1="2" x2="8" y2="6" stroke={value.stitch} stroke-width="1.3" stroke-linecap="round"/>
            </svg>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact info -->
  <section class="py-16 bg-white/[0.02] border-y border-white/5 backdrop-blur-sm">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading text-3xl text-white font-bold mb-6">Kontakt</h2>
      <p class="font-body text-white/70 mb-8">
        Haben Sie Fragen oder möchten Sie uns besuchen? Wir freuen uns auf Sie!
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        <div class="bg-transparent rounded-xl p-6">
          <svg class="w-8 h-8 mx-auto mb-3 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
          </svg>
          <p class="font-body text-sm font-medium text-white">E-Mail</p>
          <a href="mailto:info@monika-stitch.de" class="font-body text-sm text-[#C9A96E] hover:underline">info@monika-stitch.de</a>
        </div>
        <div class="bg-transparent rounded-xl p-6">
          <svg class="w-8 h-8 mx-auto mb-3 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
          </svg>
          <p class="font-body text-sm font-medium text-white">Telefon</p>
          <span class="font-body text-sm text-white/70">+49 123 456 7890</span>
        </div>
        <div class="bg-transparent rounded-xl p-6">
          <svg class="w-8 h-8 mx-auto mb-3 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
          </svg>
          <p class="font-body text-sm font-medium text-white">Standort</p>
          <span class="font-body text-sm text-white/70">Bayern, Deutschland</span>
        </div>
      </div>
    </div>
  </section>
</MainLayout>
