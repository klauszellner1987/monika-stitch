---
import MainLayout from "../layouts/MainLayout.astro";
import StickanfrageForm from "../components/StickanfrageForm.astro";
---

<MainLayout title="Monika Stitch – Stickanfrage">
  <!-- Header -->
  <section class="py-16 sm:py-20 bg-cream">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="font-body text-sm uppercase tracking-[0.3em] text-sage-dark mb-3">Ihr Wunsch wird Realität</p>
      <h1 class="font-heading text-4xl sm:text-5xl text-charcoal font-bold mb-6">Stickanfrage</h1>
      <p class="font-body text-lg text-charcoal-light max-w-2xl mx-auto leading-relaxed">
        Sie haben eine besondere Idee? Erzählen Sie uns davon! Ob Logo, Schriftzug, Bild oder etwas
        ganz anderes – wir setzen Ihre Vision in hochwertige Stickkunst um.
      </p>
    </div>
  </section>

  <!-- How it works -->
  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-2xl sm:text-3xl text-charcoal font-bold text-center mb-12">So funktioniert's</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="group relative overflow-hidden bg-white rounded-2xl p-8 text-center shadow-sm hover:shadow-lg hover:-translate-y-1.5 transition-all duration-300 border-t-4 border-rose">
          <div class="w-16 h-16 mx-auto mb-5 rounded-full bg-cream flex items-center justify-center group-hover:bg-rose-light/30 transition-colors duration-300">
            <svg class="w-8 h-8 text-gold group-hover:scale-110 group-hover:rotate-6 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
            </svg>
          </div>
          <h3 class="font-heading text-lg text-charcoal font-semibold mb-2">Anfrage senden</h3>
          <p class="font-body text-sm text-charcoal-light">Beschreiben Sie Ihr Wunschmotiv und laden Sie optional eine Vorlage hoch.</p>
          <svg class="absolute bottom-3 right-3 w-7 h-7 opacity-[0.07] group-hover:opacity-[0.15] transition-opacity duration-300" viewBox="0 0 16 12" fill="none" aria-hidden="true">
            <line x1="2" y1="2" x2="6" y2="6" stroke="#D4A5A5" stroke-width="1.3" stroke-linecap="round"/><line x1="6" y1="2" x2="2" y2="6" stroke="#D4A5A5" stroke-width="1.3" stroke-linecap="round"/>
            <line x1="8" y1="2" x2="12" y2="6" stroke="#D4A5A5" stroke-width="1.3" stroke-linecap="round"/><line x1="12" y1="2" x2="8" y2="6" stroke="#D4A5A5" stroke-width="1.3" stroke-linecap="round"/>
          </svg>
        </div>
        <div class="group relative overflow-hidden bg-white rounded-2xl p-8 text-center shadow-sm hover:shadow-lg hover:-translate-y-1.5 transition-all duration-300 border-t-4 border-sage">
          <div class="w-16 h-16 mx-auto mb-5 rounded-full bg-cream flex items-center justify-center group-hover:bg-sage/20 transition-colors duration-300">
            <svg class="w-8 h-8 text-gold group-hover:scale-110 group-hover:rotate-6 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155"/>
            </svg>
          </div>
          <h3 class="font-heading text-lg text-charcoal font-semibold mb-2">Angebot erhalten</h3>
          <p class="font-body text-sm text-charcoal-light">Wir melden uns mit einem unverbindlichen Angebot und besprechen die Details.</p>
          <svg class="absolute bottom-3 right-3 w-7 h-7 opacity-[0.07] group-hover:opacity-[0.15] transition-opacity duration-300" viewBox="0 0 16 12" fill="none" aria-hidden="true">
            <line x1="2" y1="2" x2="6" y2="6" stroke="#9CAF88" stroke-width="1.3" stroke-linecap="round"/><line x1="6" y1="2" x2="2" y2="6" stroke="#9CAF88" stroke-width="1.3" stroke-linecap="round"/>
            <line x1="8" y1="2" x2="12" y2="6" stroke="#9CAF88" stroke-width="1.3" stroke-linecap="round"/><line x1="12" y1="2" x2="8" y2="6" stroke="#9CAF88" stroke-width="1.3" stroke-linecap="round"/>
          </svg>
        </div>
        <div class="group relative overflow-hidden bg-white rounded-2xl p-8 text-center shadow-sm hover:shadow-lg hover:-translate-y-1.5 transition-all duration-300 border-t-4 border-gold">
          <div class="w-16 h-16 mx-auto mb-5 rounded-full bg-cream flex items-center justify-center group-hover:bg-gold/20 transition-colors duration-300">
            <svg class="w-8 h-8 text-gold group-hover:scale-110 group-hover:rotate-6 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 11.25v8.25a1.5 1.5 0 01-1.5 1.5H5.25a1.5 1.5 0 01-1.5-1.5v-8.25M12 4.875A2.625 2.625 0 109.375 7.5H12m0-2.625V7.5m0-2.625A2.625 2.625 0 1114.625 7.5H12m0 0V21m-8.625-9.75h18c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125h-18c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z"/>
            </svg>
          </div>
          <h3 class="font-heading text-lg text-charcoal font-semibold mb-2">Unikat erhalten</h3>
          <p class="font-body text-sm text-charcoal-light">Ihre Auftragsarbeit wird mit Präzision angefertigt und liebevoll versendet.</p>
          <svg class="absolute bottom-3 right-3 w-7 h-7 opacity-[0.07] group-hover:opacity-[0.15] transition-opacity duration-300" viewBox="0 0 16 12" fill="none" aria-hidden="true">
            <line x1="2" y1="2" x2="6" y2="6" stroke="#C9A96E" stroke-width="1.3" stroke-linecap="round"/><line x1="6" y1="2" x2="2" y2="6" stroke="#C9A96E" stroke-width="1.3" stroke-linecap="round"/>
            <line x1="8" y1="2" x2="12" y2="6" stroke="#C9A96E" stroke-width="1.3" stroke-linecap="round"/><line x1="12" y1="2" x2="8" y2="6" stroke="#C9A96E" stroke-width="1.3" stroke-linecap="round"/>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <StickanfrageForm />
</MainLayout>
