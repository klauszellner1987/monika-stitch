---
import MainLayout from "../layouts/MainLayout.astro";
const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + "/";
---

<MainLayout title="Monika Stitch – Über uns">
  <!-- Hero -->
  <section class="py-16 sm:py-20 bg-cream">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="font-body text-sm uppercase tracking-[0.3em] text-gold-dark mb-3">Unsere Geschichte</p>
      <h1 class="font-heading text-4xl sm:text-5xl text-charcoal font-bold mb-6">Über Monika Stitch</h1>
      <p class="font-body text-lg text-charcoal-light max-w-2xl mx-auto leading-relaxed">
        Hinter jedem Stich steckt Leidenschaft, Kreativität und jahrelange Erfahrung.
      </p>
    </div>
  </section>

  <!-- Story -->
  <section class="py-16 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="font-heading text-3xl text-charcoal font-bold mb-6">Die Liebe zum Faden</h2>
          <div class="space-y-4 font-body text-charcoal-light leading-relaxed">
            <p>
              Was als kleines Hobby begann, ist heute eine Leidenschaft, die in jedem einzelnen Stich spürbar ist.
              Monika Stitch steht für handgemachte Stickkunst, die von Herzen kommt.
            </p>
            <p>
              Mit viel Geduld, Kreativität und einem Auge für Details entstehen in unserer Werkstatt
              einzigartige Stickarbeiten – von individualisierten Geschenken über kunstvolle Wandbilder
              bis hin zu bestickten Textilien.
            </p>
            <p>
              Jedes Stück erzählt eine Geschichte. Ob Ihre eigene Idee oder ein Design aus unserer
              Kollektion – bei uns wird Handarbeit noch großgeschrieben.
            </p>
          </div>
        </div>

        <div class="relative">
          <div class="aspect-[4/3] rounded-2xl bg-gradient-to-br from-rose-light/30 to-sage/20 flex items-center justify-center overflow-hidden">
            <svg width="200" height="200" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg" class="opacity-60">
              <circle cx="100" cy="100" r="80" stroke="#C9A96E" stroke-width="3" fill="none"/>
              <circle cx="100" cy="100" r="70" stroke="#C9A96E" stroke-width="1.5" fill="none" opacity="0.5"/>
              <path d="M60 80 C70 60 90 70 100 90 S120 110 130 95" stroke="#D4A5A5" stroke-width="3" fill="none" stroke-linecap="round"/>
              <path d="M55 110 C65 90 85 100 95 120 S115 140 125 125" stroke="#9CAF88" stroke-width="3" fill="none" stroke-linecap="round"/>
              <path d="M70 130 C80 115 95 125 105 135 S120 125 130 130" stroke="#C9A96E" stroke-width="2" fill="none" stroke-linecap="round"/>
            </svg>
          </div>
          <div class="absolute -bottom-4 -right-4 w-24 h-24 bg-rose-light/20 rounded-2xl -z-10"></div>
          <div class="absolute -top-4 -left-4 w-16 h-16 bg-sage/10 rounded-xl -z-10"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-16 bg-cream">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-3xl text-charcoal font-bold text-center mb-12">Unsere Werte</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { title: "Handarbeit", desc: "Jeder Stich wird von Hand gefertigt – keine Massenproduktion." },
          { title: "Qualität", desc: "Nur die besten Materialien für langlebige Stickkunst." },
          { title: "Individualität", desc: "Ihr Wunschmotiv, Ihre Farben, Ihr Unikat." },
          { title: "Nachhaltigkeit", desc: "Bewusster Umgang mit Ressourcen und Materialien." },
        ].map((value) => (
          <div class="bg-white rounded-xl p-6 text-center shadow-sm">
            <h3 class="font-heading text-lg text-charcoal font-semibold mb-2">{value.title}</h3>
            <p class="font-body text-sm text-charcoal-light">{value.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact info -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading text-3xl text-charcoal font-bold mb-6">Kontakt</h2>
      <p class="font-body text-charcoal-light mb-8">
        Haben Sie Fragen oder möchten Sie uns besuchen? Wir freuen uns auf Sie!
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        <div class="bg-cream rounded-xl p-6">
          <svg class="w-8 h-8 mx-auto mb-3 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
          </svg>
          <p class="font-body text-sm font-medium text-charcoal">E-Mail</p>
          <a href="mailto:info@monika-stitch.de" class="font-body text-sm text-rose-dark hover:underline">info@monika-stitch.de</a>
        </div>
        <div class="bg-cream rounded-xl p-6">
          <svg class="w-8 h-8 mx-auto mb-3 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
          </svg>
          <p class="font-body text-sm font-medium text-charcoal">Telefon</p>
          <span class="font-body text-sm text-charcoal-light">+49 123 456 7890</span>
        </div>
        <div class="bg-cream rounded-xl p-6">
          <svg class="w-8 h-8 mx-auto mb-3 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
          </svg>
          <p class="font-body text-sm font-medium text-charcoal">Standort</p>
          <span class="font-body text-sm text-charcoal-light">Bayern, Deutschland</span>
        </div>
      </div>
    </div>
  </section>
</MainLayout>
