---
import Layout from "../layouts/Layout.astro";
const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + "/";
---

<Layout title="Monika Stitch – Willkommen">
  <!-- Needle-threading animation overlay -->
  <div id="thread-anim" class="fixed inset-0 bg-cream z-[200] flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300">
    <div id="soft-blend" class="absolute inset-0"></div>
    <div id="anim-content" class="flex flex-col items-center anim-scene">
      <svg class="w-[88vw] max-w-2xl sm:max-w-3xl" viewBox="-80 -30 580 440" fill="none">
        <defs>
          <linearGradient id="needleMetal" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%" stop-color="#8A7A6A"/>
            <stop offset="20%" stop-color="#B5A898"/>
            <stop offset="42%" stop-color="#D4C8BA"/>
            <stop offset="50%" stop-color="#DDD2C6"/>
            <stop offset="58%" stop-color="#D4C8BA"/>
            <stop offset="80%" stop-color="#B5A898"/>
            <stop offset="100%" stop-color="#8A7A6A"/>
          </linearGradient>
        </defs>

        <!-- Needle -->
        <g class="anim-needle">
          <ellipse cx="304" cy="405" rx="12" ry="3" fill="#3D3D3D" opacity="0.05"/>
          <path d="M300,70 L304,110 L306,200 L306,300 L305,360 L303,395 L300,410 L297,395 L295,360 L294,300 L294,200 L296,110 Z" fill="url(#needleMetal)"/>
          <path d="M300,70 L304,110 L306,200 L306,300 L305,360 L303,395 L300,410 L297,395 L295,360 L294,300 L294,200 L296,110 Z" fill="none" stroke="#6B5B4B" stroke-width="0.5" opacity="0.2"/>
          <path d="M302,82 L303.5,130 L304,210 L304,340 L303.5,385" fill="none" stroke="white" stroke-width="0.8" opacity="0.25"/>
          <ellipse cx="300" cy="118" rx="5" ry="15" fill="#FAF7F2" stroke="#7A6A5A" stroke-width="0.9"/>
          <ellipse cx="300" cy="118" rx="3.2" ry="12" fill="none" stroke="#8A7A6A" stroke-width="0.3" opacity="0.3"/>
        </g>

        <!-- Thread glow -->
        <path class="anim-thread-glow" d="M-60,380 C-20,360 40,280 100,210 C160,140 200,50 270,15 C320,-10 360,10 350,55 C340,100 328,108 300,118 C272,128 255,170 260,230" stroke="#E8CBCB" stroke-width="7" stroke-linecap="round" opacity="0.25"/>
        <!-- Thread -->
        <path class="anim-thread" d="M-60,380 C-20,360 40,280 100,210 C160,140 200,50 270,15 C320,-10 360,10 350,55 C340,100 328,108 300,118 C272,128 255,170 260,230" stroke="#D4A5A5" stroke-width="3.2" stroke-linecap="round"/>
      </svg>

      <p class="anim-brand font-heading text-4xl sm:text-5xl text-charcoal tracking-wide mt-8">Monika Stitch</p>
    </div>
  </div>

  <div class="relative min-h-screen w-full overflow-hidden bg-cream flex items-center justify-center">
    <!-- Animated thread lines -->
    <svg class="absolute inset-0 w-full h-full" preserveAspectRatio="none" viewBox="0 0 1000 1000">
      <path class="thread thread-1" d="M-50,200 C150,180 300,350 500,300 S750,180 1050,250" fill="none" stroke="#D4A5A5" stroke-width="1.5" opacity="0.5"/>
      <path class="thread thread-2" d="M-50,500 C200,450 350,600 550,520 S800,400 1050,480" fill="none" stroke="#9CAF88" stroke-width="1.5" opacity="0.4"/>
      <path class="thread thread-3" d="M-50,750 C100,700 400,850 600,780 S850,650 1050,720" fill="none" stroke="#C9A96E" stroke-width="1.5" opacity="0.45"/>
      <path class="thread thread-4" d="M200,-50 C220,150 100,350 250,500 S400,700 350,1050" fill="none" stroke="#D4A5A5" stroke-width="1" opacity="0.3"/>
      <path class="thread thread-5" d="M700,-50 C680,200 800,400 720,550 S600,750 650,1050" fill="none" stroke="#9CAF88" stroke-width="1" opacity="0.3"/>
    </svg>

    <div class="relative z-10 flex flex-col items-center text-center px-6">
      <div class="splash-title">
        <!-- Title: "Monika Stitch" with needle overlaying the "i" -->
        <h1 class="font-heading text-6xl sm:text-7xl md:text-8xl lg:text-9xl tracking-tight text-charcoal leading-none font-normal">
          Mon<span class="i-slot"><span class="invisible">i</span><svg class="needle-overlay" viewBox="0 0 50 180" fill="none" xmlns="http://www.w3.org/2000/svg"><defs><linearGradient id="nm" x1="0" y1="0" x2="1" y2="0"><stop offset="0%" stop-color="#8A7A6A"/><stop offset="25%" stop-color="#B5A898"/><stop offset="45%" stop-color="#CFC3B5"/><stop offset="55%" stop-color="#CFC3B5"/><stop offset="75%" stop-color="#B5A898"/><stop offset="100%" stop-color="#8A7A6A"/></linearGradient></defs><path d="M25,0 L27.5,35 L28,80 L27.5,125 L27,160 L23,160 L22.5,125 L22,80 L22.5,35 Z" fill="url(#nm)"/><path d="M25,0 L27.5,35 L28,80 L27.5,125 L27,160 L23,160 L22.5,125 L22,80 L22.5,35 Z" fill="none" stroke="#6B5B4B" stroke-width="0.4" opacity="0.4"/><ellipse cx="25" cy="30" rx="2.2" ry="8.5" fill="#FAF7F2" stroke="#7A6A5A" stroke-width="0.7"/><path d="M27.2,26 C35,16 44,2 48,-14 C50,-22 44,-22 38,-12 C33,-3 34,12 30,22" fill="none" stroke="#D4A5A5" stroke-width="2.5" stroke-linecap="round"/></svg></span>ka Stitch
        </h1>

      </div>

      <!-- Embroidery hoop -->
      <div class="splash-hoop mt-4 mb-10">
        <svg width="140" height="154" viewBox="0 0 140 154" fill="none">
          <defs>
            <linearGradient id="hoopGrad" x1="0" y1="0" x2="0.7" y2="1">
              <stop offset="0%" stop-color="#D9BD78"/>
              <stop offset="35%" stop-color="#C9A96E"/>
              <stop offset="70%" stop-color="#B89A5E"/>
              <stop offset="100%" stop-color="#D4B06A"/>
            </linearGradient>
            <radialGradient id="fabricBg" cx="50%" cy="50%" r="50%">
              <stop offset="0%" stop-color="#FDFAF5"/>
              <stop offset="85%" stop-color="#F5F0E8"/>
              <stop offset="100%" stop-color="#EDE6DA"/>
            </radialGradient>
            <clipPath id="hoopClip">
              <circle cx="70" cy="78" r="44"/>
            </clipPath>
          </defs>

          <!-- Hoop shadow -->
          <ellipse cx="72" cy="150" rx="36" ry="3.5" fill="#3D3D3D" opacity="0.05"/>

          <!-- Fabric background -->
          <circle cx="70" cy="78" r="44" fill="url(#fabricBg)"/>

          <!-- Fabric grid (clipped to hoop) -->
          <g clip-path="url(#hoopClip)" opacity="0.3">
            <line x1="28" y1="42" x2="112" y2="42" stroke="#DCCFBF" stroke-width="0.4"/>
            <line x1="28" y1="50" x2="112" y2="50" stroke="#DCCFBF" stroke-width="0.4"/>
            <line x1="28" y1="58" x2="112" y2="58" stroke="#DCCFBF" stroke-width="0.4"/>
            <line x1="28" y1="66" x2="112" y2="66" stroke="#DCCFBF" stroke-width="0.4"/>
            <line x1="28" y1="74" x2="112" y2="74" stroke="#DCCFBF" stroke-width="0.4"/>
            <line x1="28" y1="82" x2="112" y2="82" stroke="#DCCFBF" stroke-width="0.4"/>
            <line x1="28" y1="90" x2="112" y2="90" stroke="#DCCFBF" stroke-width="0.4"/>
            <line x1="28" y1="98" x2="112" y2="98" stroke="#DCCFBF" stroke-width="0.4"/>
            <line x1="28" y1="106" x2="112" y2="106" stroke="#DCCFBF" stroke-width="0.4"/>
            <line x1="28" y1="114" x2="112" y2="114" stroke="#DCCFBF" stroke-width="0.4"/>
            <line x1="34" y1="30" x2="34" y2="126" stroke="#DCCFBF" stroke-width="0.4"/>
            <line x1="42" y1="30" x2="42" y2="126" stroke="#DCCFBF" stroke-width="0.4"/>
            <line x1="50" y1="30" x2="50" y2="126" stroke="#DCCFBF" stroke-width="0.4"/>
            <line x1="58" y1="30" x2="58" y2="126" stroke="#DCCFBF" stroke-width="0.4"/>
            <line x1="66" y1="30" x2="66" y2="126" stroke="#DCCFBF" stroke-width="0.4"/>
            <line x1="74" y1="30" x2="74" y2="126" stroke="#DCCFBF" stroke-width="0.4"/>
            <line x1="82" y1="30" x2="82" y2="126" stroke="#DCCFBF" stroke-width="0.4"/>
            <line x1="90" y1="30" x2="90" y2="126" stroke="#DCCFBF" stroke-width="0.4"/>
            <line x1="98" y1="30" x2="98" y2="126" stroke="#DCCFBF" stroke-width="0.4"/>
            <line x1="106" y1="30" x2="106" y2="126" stroke="#DCCFBF" stroke-width="0.4"/>
          </g>

          <!-- Embroidery design (clipped) -->
          <g clip-path="url(#hoopClip)">
            <!-- Main stem -->
            <path d="M66 80 C62 88 54 96 46 104" stroke="#7A9166" stroke-width="1.8" stroke-linecap="round" fill="none"/>
            <path d="M72 76 C78 82 86 84 94 80" stroke="#7A9166" stroke-width="1.4" stroke-linecap="round" fill="none"/>
            <path d="M56 64 C60 66 64 70 66 74" stroke="#9CAF88" stroke-width="1.2" stroke-linecap="round" fill="none"/>
            <path d="M84 60 C80 64 76 68 72 72" stroke="#9CAF88" stroke-width="1.2" stroke-linecap="round" fill="none"/>

            <!-- Leaves -->
            <path d="M46 104 C42 108 38 108 38 104 C38 100 42 98 46 100 C44 102 44 104 46 104Z" fill="#9CAF88" opacity="0.85"/>
            <path d="M48 100 C44 96 44 92 48 92 C52 92 52 96 50 98Z" fill="#9CAF88" opacity="0.7"/>
            <path d="M94 80 C98 84 100 82 98 78 C96 74 92 76 94 80Z" fill="#9CAF88" opacity="0.8"/>
            <path d="M90 78 C94 74 92 70 88 72 C84 74 86 78 90 78Z" fill="#9CAF88" opacity="0.65"/>
            <!-- Leaf veins -->
            <path d="M42 104 L46 102" stroke="#6B8254" stroke-width="0.4" opacity="0.5"/>
            <path d="M96 80 L94 78" stroke="#6B8254" stroke-width="0.4" opacity="0.5"/>

            <!-- Small buds -->
            <path d="M54 62 C52 58 54 56 56 58 C58 56 60 58 58 62 C56 64 54 64 54 62Z" fill="#D4A5A5" opacity="0.65"/>
            <path d="M84 58 C86 56 88 58 86 60 C88 62 86 64 84 62 C82 60 82 58 84 58Z" fill="#D4A5A5" opacity="0.6"/>

            <!-- Main rose - outer petals -->
            <ellipse cx="62" cy="70" rx="5.5" ry="4" fill="#D4A5A5" opacity="0.7" transform="rotate(-30 62 70)"/>
            <ellipse cx="76" cy="68" rx="5" ry="3.8" fill="#D4A5A5" opacity="0.7" transform="rotate(25 76 68)"/>
            <ellipse cx="62" cy="80" rx="5" ry="3.5" fill="#D4A5A5" opacity="0.65" transform="rotate(15 62 80)"/>
            <ellipse cx="76" cy="80" rx="5" ry="3.5" fill="#D4A5A5" opacity="0.65" transform="rotate(-20 76 80)"/>
            <ellipse cx="58" cy="74" rx="4.5" ry="3.2" fill="#D4A5A5" opacity="0.6" transform="rotate(-10 58 74)"/>
            <ellipse cx="80" cy="74" rx="4.5" ry="3.2" fill="#D4A5A5" opacity="0.6" transform="rotate(10 80 74)"/>

            <!-- Main rose - inner petals -->
            <ellipse cx="66" cy="72" rx="4" ry="3" fill="#C99292" opacity="0.8" transform="rotate(-15 66 72)"/>
            <ellipse cx="73" cy="72" rx="4" ry="3" fill="#C99292" opacity="0.8" transform="rotate(15 73 72)"/>
            <ellipse cx="66" cy="78" rx="3.5" ry="2.8" fill="#C99292" opacity="0.75" transform="rotate(20 66 78)"/>
            <ellipse cx="73" cy="78" rx="3.5" ry="2.8" fill="#C99292" opacity="0.75" transform="rotate(-20 73 78)"/>

            <!-- Rose center -->
            <circle cx="69" cy="74" r="4" fill="#C99292"/>
            <path d="M69 72 C67 71 66 73 68 74 C66 75 67 77 69 76 C71 77 72 75 70 74 C72 73 71 71 69 72Z" fill="#B88080" opacity="0.7"/>
            <circle cx="68" cy="73" r="1.2" fill="#E8CBCB" opacity="0.5"/>

            <!-- French knot details (small dots around rose) -->
            <circle cx="69" cy="74" r="0.8" fill="#C9A96E" opacity="0.6"/>
            <circle cx="60" cy="66" r="0.6" fill="#C9A96E" opacity="0.4"/>
            <circle cx="78" cy="66" r="0.6" fill="#C9A96E" opacity="0.4"/>
            <circle cx="60" cy="82" r="0.6" fill="#C9A96E" opacity="0.4"/>
            <circle cx="78" cy="82" r="0.6" fill="#C9A96E" opacity="0.4"/>

            <!-- Tiny cross-stitch marks -->
            <g stroke="#D4A5A5" stroke-width="0.5" opacity="0.3">
              <line x1="41" y1="49" x2="45" y2="53"/>
              <line x1="45" y1="49" x2="41" y2="53"/>
              <line x1="93" y1="49" x2="97" y2="53"/>
              <line x1="97" y1="49" x2="93" y2="53"/>
              <line x1="41" y1="97" x2="45" y2="101"/>
              <line x1="45" y1="97" x2="41" y2="101"/>
              <line x1="93" y1="97" x2="97" y2="101"/>
              <line x1="97" y1="97" x2="93" y2="101"/>
            </g>

            <!-- Needle with thread -->
            <line x1="88" y1="52" x2="80" y2="68" stroke="#B5A898" stroke-width="1.2" stroke-linecap="round"/>
            <ellipse cx="89" cy="51" rx="0.8" ry="2" fill="#FAF7F2" stroke="#8A7A6A" stroke-width="0.4" transform="rotate(-35 89 51)"/>
            <path d="M90 49 C96 42 102 38 106 44 C100 44 94 48 90 49" fill="none" stroke="#D4A5A5" stroke-width="1.2" stroke-linecap="round"/>
          </g>

          <!-- Outer hoop ring -->
          <circle cx="70" cy="78" r="48" stroke="url(#hoopGrad)" stroke-width="5.5" fill="none"/>
          <!-- Inner hoop ring (depth) -->
          <circle cx="70" cy="78" r="44" stroke="#C9A96E" stroke-width="1.2" fill="none" opacity="0.35"/>
          <!-- Hoop highlight -->
          <path d="M32 54 A48 48 0 0 1 90 34" stroke="white" stroke-width="1" fill="none" opacity="0.15" stroke-linecap="round"/>

          <!-- Screw mechanism -->
          <rect x="62" y="24" width="16" height="12" rx="3.5" fill="#C9A96E"/>
          <rect x="64" y="26" width="12" height="8" rx="2" fill="#B89A5E" opacity="0.5"/>
          <line x1="67" y1="28" x2="67" y2="32" stroke="#A88A4E" stroke-width="0.5" opacity="0.4"/>
          <line x1="70" y1="26" x2="70" y2="34" stroke="#D9BD78" stroke-width="0.5" opacity="0.3"/>
          <line x1="73" y1="28" x2="73" y2="32" stroke="#A88A4E" stroke-width="0.5" opacity="0.4"/>
          <!-- Screw knob -->
          <circle cx="70" cy="18" r="7" stroke="#C9A96E" stroke-width="3" fill="none"/>
          <circle cx="70" cy="18" r="7" stroke="#D9BD78" stroke-width="0.8" fill="none" opacity="0.3"/>
          <circle cx="70" cy="18" r="4.5" fill="none" stroke="#B89A5E" stroke-width="0.6" opacity="0.35"/>
          <line x1="66.5" y1="18" x2="73.5" y2="18" stroke="#A88A4E" stroke-width="1" stroke-linecap="round" opacity="0.5"/>
          <line x1="70" y1="14.5" x2="70" y2="21.5" stroke="#A88A4E" stroke-width="1" stroke-linecap="round" opacity="0.5"/>
        </svg>
      </div>

      <!-- Enter button -->
      <a id="enter-link" href={`${base}home`}
         class="splash-button group inline-flex items-center gap-2 px-10 py-4 bg-rose text-white font-body text-lg font-medium rounded-full
                hover:bg-rose-dark transition-all duration-300 hover:shadow-lg hover:scale-105 cursor-pointer">
        Entdecken
        <svg class="w-5 h-5 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </a>
    </div>
  </div>
</Layout>

<style>
  @keyframes drawThread {
    0% { stroke-dashoffset: 2000; }
    100% { stroke-dashoffset: 0; }
  }

  @keyframes floatThread {
    0%, 100% { transform: translateY(0) translateX(0); }
    25% { transform: translateY(-15px) translateX(5px); }
    50% { transform: translateY(-5px) translateX(-5px); }
    75% { transform: translateY(-20px) translateX(3px); }
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .thread {
    stroke-dasharray: 2000;
    stroke-dashoffset: 2000;
    animation: drawThread 3s ease-out forwards, floatThread 8s ease-in-out infinite;
  }

  .thread-1 { animation-delay: 0s, 3s; }
  .thread-2 { animation-delay: 0.4s, 3.4s; }
  .thread-3 { animation-delay: 0.8s, 3.8s; }
  .thread-4 { animation-delay: 1.2s, 4.2s; }
  .thread-5 { animation-delay: 1.6s, 4.6s; }

  .i-slot {
    position: relative;
    display: inline;
  }

  .needle-overlay {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    height: 1.6em;
    width: auto;
    overflow: visible;
    pointer-events: none;
  }

  .splash-title {
    opacity: 0;
    animation: fadeInUp 1s ease-out 0.5s forwards;
  }

  .splash-hoop {
    opacity: 0;
    animation: fadeInUp 1s ease-out 1s forwards;
  }

  .splash-button {
    opacity: 0;
    animation: fadeInUp 1s ease-out 1.4s forwards;
  }

  /* Needle-threading animation */
  .anim-needle { opacity: 0; }
  .anim-thread,
  .anim-thread-glow {
    stroke-dasharray: 1600;
    stroke-dashoffset: 1600;
  }
  .anim-brand { opacity: 0; }

  #thread-anim.active {
    opacity: 1;
    pointer-events: all;
  }

  #thread-anim.active .anim-needle {
    animation: needleIn 0.6s ease-out forwards;
  }

  #thread-anim.active .anim-thread {
    animation: threadSwing 2.2s cubic-bezier(0.22, 0.61, 0.36, 1) 0.4s forwards;
  }

  #thread-anim.active .anim-thread-glow {
    animation: threadSwing 2.2s cubic-bezier(0.22, 0.61, 0.36, 1) 0.45s forwards;
  }

  #thread-anim.active .anim-brand {
    animation: fadeInUp 0.5s ease-out 1.6s forwards;
  }

  #soft-blend {
    background: var(--color-cream, #FAF7F2);
    opacity: 0;
    z-index: 10;
    pointer-events: none;
  }

  #thread-anim.active #anim-content {
    animation: sceneLife 3.5s ease-out forwards;
  }

  #thread-anim.active #soft-blend {
    animation: blendIn 0.8s ease-in-out 2.7s forwards;
  }

  @keyframes needleIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes threadSwing {
    to { stroke-dashoffset: 0; }
  }

  @keyframes sceneLife {
    0% {
      transform: scale(0.96);
      opacity: 1;
      filter: blur(0px);
    }
    72% {
      transform: scale(1);
      opacity: 1;
      filter: blur(0px);
    }
    100% {
      transform: scale(1.02);
      opacity: 0.3;
      filter: blur(8px);
    }
  }

  @keyframes blendIn {
    0% { opacity: 0; }
    100% { opacity: 1; }
  }
</style>

<script>
  const link = document.getElementById("enter-link");
  const anim = document.getElementById("thread-anim");

  if (link && anim) {
    link.addEventListener("click", (e) => {
      e.preventDefault();
      const href = link.getAttribute("href");
      if (!href) return;

      anim.classList.add("active");

      setTimeout(() => {
        window.location.href = href;
      }, 3600);
    });
  }
</script>
