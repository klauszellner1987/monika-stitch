---
const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + "/";
---

<section class="relative min-h-[calc(100vh-80px)] flex items-center justify-center overflow-hidden py-8">
  <!-- Background pattern -->
  <div class="absolute inset-0 bg-[#0f172a]"></div>
  <div class="absolute inset-0 bg-gradient-to-br from-[#0f172a] via-[#1e293b]/40 to-[#0f172a]"></div>
  
  <!-- Embroidery hoop frame -->
  <div class="hero-hoop absolute inset-0 flex items-center justify-center pointer-events-none">
    <svg class="w-[300px] h-[300px] sm:w-[380px] sm:h-[380px] md:w-[460px] md:h-[460px]" viewBox="0 0 200 200" fill="none">
      <circle cx="100" cy="100" r="92" stroke="var(--color-gold)" stroke-width="3.5" opacity="0.10"/>
      <circle cx="100" cy="100" r="86" stroke="var(--color-gold)" stroke-width="1.5" opacity="0.07"/>
      <circle cx="100" cy="100" r="80" stroke="var(--color-gold)" stroke-width="0.5" opacity="0.05" stroke-dasharray="4 6"/>
    </svg>
  </div>

  <!-- Flowing thread curves -->
  <svg class="absolute inset-0 w-full h-full pointer-events-none" viewBox="0 0 1200 700" preserveAspectRatio="xMidYMid slice" fill="none">
    <path class="thread-curve" d="M-50,200 C150,80 350,320 550,180 S850,350 1050,120 L1250,250" stroke="var(--color-rose)" stroke-width="1.5" stroke-linecap="round" opacity="0.12" style="animation-delay: 0s;"/>
    <path class="thread-curve" d="M-50,500 C200,400 400,580 650,420 S900,550 1100,380 L1250,480" stroke="var(--color-gold)" stroke-width="1.3" stroke-linecap="round" opacity="0.10" style="animation-delay: -7s;"/>
    <path class="thread-curve" d="M-50,350 C100,280 300,420 500,300 S800,200 1000,350 L1250,280" stroke="var(--color-gold-light)" stroke-width="1" stroke-linecap="round" opacity="0.08" style="animation-delay: -13s;"/>
  </svg>

  <!-- Scattered embroidery motifs -->
  <div class="absolute inset-0 pointer-events-none hidden sm:block">
    <!-- Cross-stitch cluster top-left -->
    <svg class="motif absolute top-[8%] left-[4%] w-10 h-8" viewBox="0 0 40 24" fill="none" style="animation-delay: 0s;">
      <line x1="2" y1="2" x2="8" y2="8" stroke="var(--color-rose)" stroke-width="1.4" stroke-linecap="round"/><line x1="8" y1="2" x2="2" y2="8" stroke="var(--color-rose)" stroke-width="1.4" stroke-linecap="round"/>
      <line x1="12" y1="2" x2="18" y2="8" stroke="var(--color-rose)" stroke-width="1.4" stroke-linecap="round"/><line x1="18" y1="2" x2="12" y2="8" stroke="var(--color-rose)" stroke-width="1.4" stroke-linecap="round"/>
      <line x1="22" y1="2" x2="28" y2="8" stroke="var(--color-rose)" stroke-width="1.4" stroke-linecap="round"/><line x1="28" y1="2" x2="22" y2="8" stroke="var(--color-rose)" stroke-width="1.4" stroke-linecap="round"/>
      <line x1="32" y1="2" x2="38" y2="8" stroke="var(--color-rose)" stroke-width="1.4" stroke-linecap="round"/><line x1="38" y1="2" x2="32" y2="8" stroke="var(--color-rose)" stroke-width="1.4" stroke-linecap="round"/>
      <line x1="7" y1="12" x2="13" y2="18" stroke="var(--color-rose)" stroke-width="1.4" stroke-linecap="round"/><line x1="13" y1="12" x2="7" y2="18" stroke="var(--color-rose)" stroke-width="1.4" stroke-linecap="round"/>
      <line x1="17" y1="12" x2="23" y2="18" stroke="var(--color-rose)" stroke-width="1.4" stroke-linecap="round"/><line x1="23" y1="12" x2="17" y2="18" stroke="var(--color-rose)" stroke-width="1.4" stroke-linecap="round"/>
      <line x1="27" y1="12" x2="33" y2="18" stroke="var(--color-rose)" stroke-width="1.4" stroke-linecap="round"/><line x1="33" y1="12" x2="27" y2="18" stroke="var(--color-rose)" stroke-width="1.4" stroke-linecap="round"/>
    </svg>

    <!-- Flower top-right -->
    <svg class="motif absolute top-[10%] right-[12%] w-8 h-12" viewBox="0 0 24 34" fill="none" style="animation-delay: -1.5s;">
      <circle cx="12" cy="10" r="2" fill="var(--color-gold)" opacity="0.4"/>
      <path d="M12 8 Q14 3 12 1 Q10 3 12 8" stroke="var(--color-gold)" stroke-width="0.8" fill="var(--color-gold)" fill-opacity="0.12"/>
      <path d="M14 10 Q18 7 19 4 Q16 6 14 10" stroke="var(--color-gold)" stroke-width="0.8" fill="var(--color-gold)" fill-opacity="0.12"/>
      <path d="M13 12 Q17 14 19 17 Q15 14 13 12" stroke="var(--color-gold)" stroke-width="0.8" fill="var(--color-gold)" fill-opacity="0.12"/>
      <path d="M11 12 Q7 14 5 17 Q9 14 11 12" stroke="var(--color-gold)" stroke-width="0.8" fill="var(--color-gold)" fill-opacity="0.12"/>
      <path d="M10 10 Q6 7 5 4 Q8 6 10 10" stroke="var(--color-gold)" stroke-width="0.8" fill="var(--color-gold)" fill-opacity="0.12"/>
      <line x1="12" y1="14" x2="12" y2="30" stroke="var(--color-sage)" stroke-width="1.2" stroke-linecap="round"/>
      <path d="M12 22 Q8 19 6 21" fill="none" stroke="var(--color-sage)" stroke-width="1" stroke-linecap="round"/>
    </svg>

    <!-- Heart left-mid -->
    <svg class="motif absolute top-[55%] left-[6%] w-5 h-5" viewBox="0 0 24 24" fill="none" style="animation-delay: -5s;">
      <path d="M12 20 C12 20 4 14 4 9 C4 5.5 7 4 9.5 4 C10.8 4 12 5 12 6.5 C12 5 13.2 4 14.5 4 C17 4 20 5.5 20 9 C20 14 12 20 12 20Z" stroke="var(--color-rose)" stroke-width="1.3" fill="var(--color-rose)" fill-opacity="0.1"/>
    </svg>

    <!-- Leaf sprig right-mid -->
    <svg class="motif absolute top-[38%] right-[4%] w-8 h-8" viewBox="0 0 28 28" fill="none" style="animation-delay: -1s;">
      <line x1="4" y1="24" x2="24" y2="4" stroke="var(--color-sage)" stroke-width="1" stroke-linecap="round"/>
      <ellipse cx="10" cy="18" rx="3" ry="5.5" stroke="var(--color-sage)" stroke-width="0.9" transform="rotate(-45 10 18)" fill="var(--color-sage)" fill-opacity="0.06"/>
      <ellipse cx="18" cy="10" rx="3" ry="5.5" stroke="var(--color-sage)" stroke-width="0.9" transform="rotate(-45 18 10)" fill="var(--color-sage)" fill-opacity="0.06"/>
      <ellipse cx="14" cy="14" rx="2.5" ry="4.5" stroke="var(--color-sage)" stroke-width="0.8" transform="rotate(-45 14 14)" fill="var(--color-sage)" fill-opacity="0.05"/>
    </svg>

    <!-- Leaf sprig bottom-center -->
    <svg class="motif absolute bottom-[18%] left-[38%] w-6 h-6" viewBox="0 0 28 28" fill="none" style="animation-delay: -6s;">
      <line x1="4" y1="24" x2="24" y2="4" stroke="var(--color-sage-light)" stroke-width="1" stroke-linecap="round"/>
      <ellipse cx="10" cy="18" rx="2.5" ry="5" stroke="var(--color-sage-light)" stroke-width="0.8" transform="rotate(-45 10 18)" fill="var(--color-sage-light)" fill-opacity="0.06"/>
      <ellipse cx="18" cy="10" rx="2.5" ry="5" stroke="var(--color-sage-light)" stroke-width="0.8" transform="rotate(-45 18 10)" fill="var(--color-sage-light)" fill-opacity="0.06"/>
    </svg>

    <!-- Scissors bottom-right -->
    <svg class="motif absolute bottom-[28%] right-[16%] w-7 h-7" viewBox="0 0 24 24" fill="none" style="animation-delay: -2.5s;">
      <circle cx="7" cy="5" r="3.5" stroke="var(--color-gold)" stroke-width="0.9" opacity="0.4"/>
      <circle cx="7" cy="19" r="3.5" stroke="var(--color-gold)" stroke-width="0.9" opacity="0.4"/>
      <line x1="10" y1="7" x2="22" y2="14" stroke="var(--color-gold)" stroke-width="1.1" stroke-linecap="round" opacity="0.4"/>
      <line x1="10" y1="17" x2="22" y2="10" stroke="var(--color-gold)" stroke-width="1.1" stroke-linecap="round" opacity="0.4"/>
    </svg>
  </div>

  <div class="relative z-10 max-w-4xl mx-auto text-center px-5 sm:px-8 py-8 md:py-10 bg-white/5 backdrop-blur-md border border-white/10 rounded-3xl shadow-2xl">
    <img src={`${base}images/logo.svg`} alt="Monika Stitch" class="w-20 sm:w-28 md:w-32 h-auto mx-auto mb-4 drop-shadow-md" />
    <p class="font-body text-[10px] sm:text-xs md:text-sm uppercase tracking-[0.3em] text-[#C9A96E] mb-3 sm:mb-4">Handgemacht & Einzigartig</p>
    <h1 class="font-heading text-4xl sm:text-5xl md:text-5xl lg:text-6xl text-white leading-tight mb-3 sm:mb-4 drop-shadow-sm">
      Stickkunst mit<br/>
      <span class="text-[#D4A5A5] italic">Liebe</span> zum Detail
    </h1>
    <p class="font-body text-sm sm:text-base md:text-lg text-white/80 max-w-2xl mx-auto mb-6 md:mb-8 leading-relaxed">
      Individuelle Stickereien und handgefertigte Produkte – jedes Stück ein Unikat, gefertigt mit Leidenschaft und Sorgfalt.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center mt-2">
      <a href={`${base}shop`}
         class="inline-flex items-center justify-center gap-2 px-6 sm:px-8 py-3 sm:py-3.5 bg-gradient-to-r from-[#C9A96E] to-[#A88A4E] text-white font-body font-medium rounded-full hover:shadow-[0_0_20px_rgba(201,169,110,0.4)] transition-all duration-300 hover:scale-105 border border-[#D9C49A]/30">
        Zum Shop
        <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </a>
      <a href={`${base}stickanfrage`}
         class="inline-flex items-center justify-center gap-2 px-6 sm:px-8 py-3 sm:py-3.5 bg-white/5 backdrop-blur-sm border border-[#C9A96E]/50 text-white font-body font-medium rounded-full hover:bg-[#C9A96E]/10 hover:border-[#C9A96E] transition-all duration-300">
        Stickanfrage stellen
      </a>
    </div>
  </div>

  <!-- Decorative thread accents -->
  <svg class="absolute bottom-0 left-0 w-full h-24 opacity-40 pointer-events-none" preserveAspectRatio="none" viewBox="0 0 1200 100">
    <path d="M0,80 C200,40 400,90 600,50 S1000,80 1200,40" fill="none" stroke="var(--color-rose)" stroke-width="2"/>
    <path d="M0,95 C300,60 600,95 900,65 S1100,90 1200,70" fill="none" stroke="var(--color-gold)" stroke-width="1.5"/>
  </svg>
</section>

<style>
  .hero-hoop svg {
    animation: hoopPulse 8s ease-in-out infinite;
  }

  .thread-curve {
    stroke-dasharray: 1200;
    stroke-dashoffset: 1200;
    animation: threadFlow 18s linear infinite;
  }

  .motif {
    opacity: 0.12;
    animation: gentleFloat 8s ease-in-out infinite;
  }

  @keyframes hoopPulse {
    0%, 100% { transform: scale(0.98); }
    50% { transform: scale(1.03); }
  }

  @keyframes gentleFloat {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-5px) rotate(2deg); }
  }

  @keyframes threadFlow {
    0% { stroke-dashoffset: 1200; }
    50% { stroke-dashoffset: 0; }
    100% { stroke-dashoffset: -1200; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-hoop svg,
    .thread-curve,
    .motif {
      animation: none;
    }
    .thread-curve {
      stroke-dashoffset: 0;
    }
  }
</style>
