---
const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + "/";
---

<section class="relative min-h-[70vh] flex items-center justify-center overflow-hidden">
  <!-- Background pattern -->
  <div class="absolute inset-0 bg-gradient-to-br from-cream via-rose-light/20 to-cream-dark"></div>
  <div class="absolute inset-0 opacity-5">
    <svg width="100%" height="100%">
      <pattern id="stitch-pattern" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">
        <line x1="0" y1="20" x2="20" y2="0" stroke="#3D3D3D" stroke-width="0.5"/>
        <line x1="20" y1="40" x2="40" y2="20" stroke="#3D3D3D" stroke-width="0.5"/>
      </pattern>
      <rect width="100%" height="100%" fill="url(#stitch-pattern)"/>
    </svg>
  </div>

  <div class="relative z-10 max-w-4xl mx-auto text-center px-6 py-20">
    <p class="font-body text-sm uppercase tracking-[0.3em] text-rose-dark mb-6">Handgemacht & Einzigartig</p>
    <h1 class="font-heading text-4xl sm:text-5xl md:text-6xl lg:text-7xl text-charcoal leading-tight mb-6">
      Stickkunst mit<br/>
      <span class="text-rose-dark italic">Liebe</span> zum Detail
    </h1>
    <p class="font-body text-lg sm:text-xl text-charcoal-light max-w-2xl mx-auto mb-10 leading-relaxed">
      Individuelle Stickereien und handgefertigte Produkte – jedes Stück ein Unikat, gefertigt mit Leidenschaft und Sorgfalt.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href={`${base}shop`}
         class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-rose text-white font-body font-medium rounded-full hover:bg-rose-dark transition-all duration-300 hover:shadow-lg hover:scale-105">
        Zum Shop
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </a>
      <a href={`${base}stickanfrage`}
         class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-transparent border-2 border-charcoal/20 text-charcoal font-body font-medium rounded-full hover:border-sage hover:bg-sage/10 transition-all duration-300">
        Stickanfrage stellen
      </a>
    </div>
  </div>

  <!-- Decorative thread accents -->
  <svg class="absolute bottom-0 left-0 w-full h-24 opacity-30" preserveAspectRatio="none" viewBox="0 0 1200 100">
    <path d="M0,80 C200,40 400,90 600,50 S1000,80 1200,40" fill="none" stroke="#D4A5A5" stroke-width="2"/>
    <path d="M0,95 C300,60 600,95 900,65 S1100,90 1200,70" fill="none" stroke="#9CAF88" stroke-width="1.5"/>
  </svg>
</section>
